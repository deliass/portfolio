<style>
  footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s-m);
    width: 100%;
    padding: var(--space-xl);
    border-radius: 30px;
    background: var(--secondary);
  }

  .footer {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .plan,
  .social,
  .mentions {
    display: flex;
    flex-direction: column;
    gap: var(--space-s-m);
  }

  @media (max-width: 480px) {
    .footer {
      display: grid;
      grid-template-columns: repeat(1, 1fr);
      gap: var(--space-s);
    }
  }

  h3 {
    color: var(--title);
    font-family: "ABC Favorit Mono Edu";
    font-size: var(--step-3);
    text-align: center;
  }

  a {
    color: var(--text-primary);
    font-family: "Fibra One";
    font-size: var(--step-0);
    font-weight: bold;
    text-decoration: none;
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
  }
</style>
