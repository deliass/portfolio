---
import Button from "../components/Button.astro";
---

<section class="cv">
  <div class="cv__inner">
    <h2>Garder mon CV</h2>
    <p>
      Si mes projets vous plaisent, vous pouvez télécharger mon CV pour garder
      une vue d’ensemble de ma vie professionnelle.
    </p>
    <div class="cv__assets">
      <Button
        title="Télécharger mon CV"
        link="/figuerola-nélia_cv.pdf"
        type="button"
        download
      />
      <img src="/public/assets/icons/cv.svg" alt="" width="78" height="68" />
    </div>
  </div>
</section>

<style>
  h2 {
    color: #733635;
    font-family: "ABC Favorit Mono Edu";
    font-size: 44px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  .cv {
    align-items: center;
    justify-content: center;
    width: 100%;
    background: #ececdc;
  }

  .cv__inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 20px;
    padding: 60px 120px;
    box-sizing: border-box;
  }

  .cv__assets {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
  }

  p {
    color: #351e1c;
    font-family: "Fibra One";
    font-size: 20px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

	@media (max-width: 768px) {
  .cv__inner {
    padding: 40px 24px;
    gap: 16px;
  }

  h2 {
    font-size: 32px;
    text-align: center;
  }

  p {
    font-size: 18px;
  }

  .cv__assets {
    flex-direction: column;
    align-items: stretch;
    gap: 16px;
  }

  .cv__assets img {
    margin: 0 auto;
    width: 56px;
    height: auto;
  }
}

@media (max-width: 480px) {
  h2 {
    font-size: 28px;
  }

  p {
    font-size: 16px;
  }

  .cv__inner {
    padding: 24px 16px;
  }

  .cv__assets {
    gap: 12px;
  }
}
</style>

